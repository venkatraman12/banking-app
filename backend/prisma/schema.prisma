generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  dateOfBirth  DateTime?
  address      String?
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts     Account[]
  cards        Card[]
  loans        Loan[]
  savingsGoals SavingsGoal[]
  investments  Investment[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id        String        @id @default(cuid())
  userId    String
  name      String
  type      AccountType
  number    String        @unique
  balance   Decimal       @default(0) @db.Decimal(15, 2)
  currency  String        @default("USD")
  status    AccountStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentTx       Transaction[] @relation("FromAccount")
  receivedTx   Transaction[] @relation("ToAccount")
  cards        Card[]

  @@map("accounts")
}

model Transaction {
  id            String            @id @default(cuid())
  fromAccountId String?
  toAccountId   String?
  amount        Decimal           @db.Decimal(15, 2)
  type          TransactionType
  category      String?
  description   String?
  status        TransactionStatus @default(COMPLETED)
  reference     String            @unique @default(cuid())
  createdAt     DateTime          @default(now())

  fromAccount Account? @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount   Account? @relation("ToAccount", fields: [toAccountId], references: [id])

  @@map("transactions")
}

model Card {
  id        String     @id @default(cuid())
  userId    String
  accountId String
  type      CardType
  label     String
  last4     String
  expiry    String
  network   String     @default("Visa")
  status    CardStatus @default(ACTIVE)
  limit     Decimal    @default(5000) @db.Decimal(15, 2)
  spent     Decimal    @default(0) @db.Decimal(15, 2)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@map("cards")
}

model Loan {
  id          String     @id @default(cuid())
  userId      String
  type        LoanType
  name        String
  principal   Decimal    @db.Decimal(15, 2)
  outstanding Decimal    @db.Decimal(15, 2)
  rate        Decimal    @db.Decimal(5, 2)
  monthly     Decimal    @db.Decimal(15, 2)
  termMonths  Int
  status      LoanStatus @default(ACTIVE)
  nextDueDate DateTime
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("loans")
}

model SavingsGoal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  emoji     String   @default("🎯")
  target    Decimal  @db.Decimal(15, 2)
  saved     Decimal  @default(0) @db.Decimal(15, 2)
  monthly   Decimal  @default(0) @db.Decimal(15, 2)
  deadline  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

model Investment {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  name      String
  shares    Decimal  @db.Decimal(15, 6)
  avgPrice  Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@map("investments")
}

// ── Enums ──────────────────────────────────────
enum Role {
  USER
  ADMIN
}

enum AccountType {
  CHECKING
  SAVINGS
  INVESTMENT
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  FROZEN
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  FEE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum CardType {
  DEBIT
  CREDIT
  VIRTUAL
  PREPAID
}

enum CardStatus {
  ACTIVE
  FROZEN
  BLOCKED
  EXPIRED
}

enum LoanType {
  PERSONAL
  HOME
  AUTO
  BUSINESS
  STUDENT
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  PENDING
}
